    {key:"recruiting.templates",label:"📝 Шаблоны объявлений"},
    {key:"recruiting.objections",label:"💬 Обработка возражений"},
    {key:"sop.daily",label:"📋 Ежедневный чеклист"},
    {key:"countries.ph",label:"🇵🇭 Филиппины"},
    {key:"countries.id",label:"🇮🇩 Индонезия"},
    {key:"recruiting.automation",label:"⚙ Автоматизация"},
    {key:"checklists.launch",label:"🚀 Чеклист запуска"},
    {key:"brand.voice",label:"🗣 Tone of Voice"},
  ];

  let html = `<h1 class="page-title">Dashboard</h1>
    <p class="p">Apex Talent Knowledge Base — все гайды, SOP и инструменты</p>
    <div class="dash-stats">
      <div class="card dash-stat"><div class="dash-stat-val" style="color:var(--mag)">${Object.keys(SECTIONS).length}</div><div class="dash-stat-label">Разделов</div></div>
      <div class="card dash-stat"><div class="dash-stat-val" style="color:var(--ink)">${totalPages}</div><div class="dash-stat-label">Страниц</div></div>
      <div class="card dash-stat"><div class="dash-stat-val" style="color:#22C55E">${totalChecks}</div><div class="dash-stat-label">Чеклистов</div></div>
      <div class="card dash-stat"><div class="dash-stat-val" style="color:#C9A84C">${doneItems}/${totalItems}</div><div class="dash-stat-label">Выполнено</div></div>
    </div>
    <h2 class="h3">Быстрый доступ</h2>
    <div class="dash-links">${quickLinks.map(l=>`<button class="dash-link" onclick="nav('${l.key.split('.')[0]}','${l.key.split('.')[1]}')">${l.label}</button>`).join('')}</div>`;
  return html;
}

function renderContent(){
  const el = document.getElementById('content');
  if(state.sec==='dashboard'){
    el.innerHTML = renderDashboard();
    return;
  }
  const key = state.sec+'.'+state.sub;
  const c = C[key];
  if(!c){
    el.innerHTML = '<div class="placeholder"><div class="placeholder-icon">📄</div><div>Выбери раздел</div></div>';
    return;
  }
  el.innerHTML = `<h1 class="page-title">${c.title}</h1>${c.blocks.map(renderBlock).join('')}`;
}

function nav(sec,sub){
  state.sec=sec; state.sub=sub;
  renderSidebar(); renderBreadcrumb(); renderContent();
  closeSidebar();
  window.scrollTo(0,0);
}

function toggleSidebar(){
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sb-overlay').classList.toggle('show');
}
function closeSidebar(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sb-overlay').classList.remove('show');
}

// Search
function handleSearch(q){
  const res = document.getElementById('search-results');
  if(q.length<2){ res.style.display='none'; return; }
  const lower = q.toLowerCase();
  const matches = Object.entries(C).filter(([k,v])=>JSON.stringify(v).toLowerCase().includes(lower)).slice(0,8);
  if(!matches.length){ res.style.display='none'; return; }
  res.style.display='block';
  res.innerHTML = matches.map(([k,v])=>`<button class="search-item" onclick="navFromSearch('${k}')">${v.title}</button>`).join('');
}
function navFromSearch(key){
  const [s,sub]=key.split('.');
  nav(s,sub);
  document.getElementById('search-input').value='';
  document.getElementById('search-results').style.display='none';
}
document.addEventListener('click',e=>{
  if(!e.target.closest('.search-input')&&!e.target.closest('.search-results'))
    document.getElementById('search-results').style.display='none';
});

function initApp(){
  renderSidebar(); renderBreadcrumb(); renderContent();
}
</script>

</body>
</html>