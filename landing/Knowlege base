    <svg width="40" height="40" viewBox="0 0 80 80" fill="none" style="margin-bottom:16px"><polygon points="40,16 18,62 30,62 40,38 50,62 62,62" fill="#1A0F2E"/></svg>
    <h1 class="font-h" style="font-weight:900;font-size:20px;color:var(--ink);margin-bottom:4px">APEX TALENT</h1>
    <p style="font-size:13px;color:var(--t2);margin-bottom:24px">Knowledge Base</p>
