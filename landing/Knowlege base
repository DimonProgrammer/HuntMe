}

function renderBlock(b){
  switch(b.t){
    case 'h': return `<h3 class="h3 mt">${b.v}</h3>`;
    case 'p': return `<p class="p">${b.v}</p>`;
    case 'kv': return `<div class="kv"><div class="kv-label">${b.l}</div><div class="kv-value">${b.v}</div></div>`;
    case 'li': return b.items.map(i=>`<div class="list-item"><span class="list-dot">●</span><span class="list-text">${i}</span></div>`).join('')+'<div style="margin-bottom:16px"></div>';
    case 'stats': return `<div class="stat-grid">${b.items.map(s=>`<div class="stat-card"><div class="stat-label">${s.l}</div><div class="stat-value">${s.v}</div></div>`).join('')}</div>`;
    case 'tracks': return b.items.map(c=>`<div class="track-card" style="border-left:4px solid ${c.accent}"><div class="track-title">${c.title}</div><div class="track-sub" style="color:${c.accent}">${c.sub}</div><div class="track-details">${c.details}</div></div>`).join('');
    case 'colors': return b.items.map(c=>`<div class="color-row"><div class="color-swatch" style="background:${c.hex};${c.hex.includes('FFF')?'border:1px solid var(--border)':''}"></div><div><div class="color-name">${c.name} <span class="color-hex">${c.hex.length<20?c.hex:''}</span></div><div class="color-usage">${c.usage}</div></div></div>`).join('')+'<div style="margin-bottom:20px"></div>';
    case 'tbl': return `<div class="tbl-wrap"><table><thead><tr>${b.headers.map(h=>`<th>${h}</th>`).join('')}</tr></thead><tbody>${b.rows.map(r=>`<tr>${r.map(c=>`<td>${c}</td>`).join('')}</tr>`).join('')}</tbody></table></div>`;
    case 'copy': return `<div class="copy-card"><div class="copy-header"><span class="copy-label">${b.l}</span><button class="copy-btn" onclick="copyText(this,'${esc(b.v)}')">📋 Копировать</button></div><div class="copy-text">${b.v.replace(/\n/g,'<br>')}</div></div>`;
    case 'alert': return `<div class="alert ${b.variant==='err'?'alert-err':'alert-warn'}">${b.v}</div>`;
    case 'placeholder': return `<div class="placeholder"><div class="placeholder-icon">🚧</div><div>${b.v}</div></div>`;
    case 'check':
      if(!checks[b.id]) checks[b.id] = new Array(b.items.length).fill(false);
      const done = checks[b.id].filter(Boolean).length;
      const pct = (done/b.items.length*100).toFixed(0);
      let h = `<div class="check-progress">${done} / ${b.items.length} выполнено</div>`;
      h += `<div class="check-bar"><div class="check-fill" style="width:${pct}%"></div></div>`;
      b.items.forEach((item,j)=>{
        const ch = checks[b.id][j];
        h += `<label class="check-item${ch?' done':''}"><input type="checkbox" ${ch?'checked':''} onchange="toggleCheck('${b.id}',${j})"><span>${item}</span></label>`;
      });
      return h;
    default: return '';
  }
}

function esc(s){ return s.replace(/'/g,"\\'").replace(/\n/g,'\\n'); }

function copyText(btn,text){
  navigator.clipboard.writeText(text.replace(/\\n/g,'\n'));
  btn.textContent = '✓ Скопировано';
  btn.classList.add('done');
  setTimeout(()=>{ btn.textContent='📋 Копировать'; btn.classList.remove('done'); },2000);
}

function toggleCheck(id,idx){
  checks[id][idx] = !checks[id][idx];
  saveChecks();
  renderContent();
}

