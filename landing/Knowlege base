  </div>
</div>

<script>
// ═══ AUTH ═══
const PASS = "8008";
function tryAuth(){
  const v = document.getElementById('pin-input').value;
  if(v === PASS){
    localStorage.setItem('kb-auth','1');
    document.getElementById('auth-screen').classList.add('hidden');
    document.getElementById('app').classList.add('show');
    initApp();
  } else {
    document.getElementById('auth-err').textContent = 'Неверный пароль';
    document.getElementById('pin-input').value = '';
  }
}
document.getElementById('pin-input').addEventListener('keydown', e => { if(e.key==='Enter') tryAuth(); });
if(localStorage.getItem('kb-auth')==='1'){
  document.getElementById('auth-screen').classList.add('hidden');
  document.getElementById('app').classList.add('show');
  setTimeout(initApp, 0);
}

