function renderSidebar(){
  let html = '';
  for(const [key,sec] of Object.entries(SECTIONS)){
    const active = state.sec===key;
    html += `<button class="sb-section${active?' active':''}" onclick="nav('${key}','${Object.keys(sec.subs)[0]}')">${sec.icon} ${sec.title}</button>`;
    if(active){
      html += '<div style="padding-left:48px">';
      for(const [sk,st] of Object.entries(sec.subs)){
        html += `<button class="sb-sub${state.sub===sk?' active':''}" onclick="nav('${key}','${sk}')">${st}</button>`;
      }
