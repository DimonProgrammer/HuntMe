      <div>
        <div class="font-h" style="font-weight:900;font-size:12px;letter-spacing:0.1em;color:var(--ink)">APEX TALENT</div>
        <div style="font-size:10px;color:var(--t2)">Knowledge Base</div>
      </div>
    </div>
    <nav id="sidebar-nav"></nav>
  </aside>

  <!-- Main -->

  <div class="main">
    <div class="topbar">
      <button class="hamburger" onclick="toggleSidebar()">☰</button>
      <div style="flex:1;position:relative;max-width:480px">
        <input type="text" class="search-input" id="search-input" placeholder="🔍 Поиск по базе знаний..." oninput="handleSearch(this.value)">
        <div class="search-results" id="search-results" style="display:none"></div>
