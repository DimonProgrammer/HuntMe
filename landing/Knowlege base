<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
--ink:#1A0F2E;--mag:#E33BC5;--lime:#CCFF00;
--t2:rgba(26,15,46,0.55);--t3:rgba(26,15,46,0.35);
--bg1:#FFF5F0;--bg2:#FFFAED;--bg3:#FFF3B0;
--card:#FFFFFF;--border:rgba(26,15,46,0.08);
--shadow:0 12px 32px -8px rgba(26,15,46,0.08);
--radius:16px;
}
html{scroll-behavior:smooth}
body{font-family:'Plus Jakarta Sans',sans-serif;color:var(--ink);background:linear-gradient(150deg,var(--bg1) 0%,var(--bg2) 50%,var(--bg3) 100%);background-attachment:fixed;min-height:100vh;-webkit-font-smoothing:antialiased}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:0.4}
.font-h{font-family:'Outfit',sans-serif}

/* Auth */
#auth-screen{position:fixed;inset:0;z-index:9999;background:linear-gradient(150deg,var(–bg1),var(–bg2),var(–bg3));display:flex;align-items:center;justify-content:center;padding:20px}
#auth-screen.hidden{display:none}
.auth-card{background:var(–card);border-radius:20px;box-shadow:var(–shadow);padding:40px 32px;max-width:340px;width:100%;text-align:center}
.auth-input{width:100%;padding:14px 16px;border:2px solid var(–border);border-radius:12px;font-size:18px;outline:none;text-align:center;font-family:‘Plus Jakarta Sans’,sans-serif;background:#FAFAFA;letter-spacing:0.15em;transition:border-color 0.2s}
.auth-input:focus{border-color:var(–mag)}
.auth-btn{width:100%;padding:14px;background:var(–mag);color:#fff;border:none;border-radius:12px;font-family:‘Outfit’,sans-serif;font-weight:800;font-size:15px;cursor:pointer;margin-top:12px;transition:filter 0.2s}
.auth-btn:hover{filter:brightness(1.1)}
.auth-err{color:#E33B3C;font-size:12px;margin-top:8px;min-height:18px}

/* Layout */
#app{display:none}
#app.show{display:flex;min-height:100vh;position:relative;z-index:1}

/* Sidebar */
.sidebar{width:256px;background:var(–card);border-right:1px solid var(–border);position:fixed;top:0;left:-256px;bottom:0;z-index:50;overflow-y:auto;padding:20px 0;transition:left 0.3s ease}
.sidebar.open{left:0}
.sb-overlay{position:fixed;inset:0;background:rgba(26,15,46,0.25);z-index:40;display:none}
.sb-overlay.show{display:block}
@media(min-width:768px){
.sidebar{position:sticky;left:0!important;top:0;flex-shrink:0;height:100vh}
.sb-overlay{display:none!important}
.hamburger{display:none!important}
}
.sb-logo{display:flex;align-items:center;gap:8px;padding:0 20px;margin-bottom:24px}
.sb-section{width:100%;display:flex;align-items:center;gap:10px;padding:10px 20px;border:none;background:transparent;cursor:pointer;font-size:13px;font-weight:500;color:var(–ink);font-family:‘Plus Jakarta Sans’,sans-serif;text-align:left;border-left:3px solid transparent;transition:all 0.15s}
.sb-section.active{background:rgba(227,59,197,0.06);color:var(–mag);font-weight:700;border-left-color:var(–mag)}
.sb-sub{display:block;width:100%;padding:6px 12px;border:none;background:transparent;cursor:pointer;font-size:12px;text-align:left;color:var(–t2);font-weight:400;font-family:‘Plus Jakarta Sans’,sans-serif;border-radius:6px;margin-bottom:2px;transition:all 0.15s}
.sb-sub.active{background:rgba(227,59,197,0.04);color:var(–mag);font-weight:600}

/* Top bar */
.topbar{position:sticky;top:0;z-index:30;background:rgba(255,245,240,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(–border);padding:12px 20px;display:flex;align-items:center;gap:12px}
.search-input{flex:1;max-width:480px;padding:10px 16px;border:1.5px solid var(–border);border-radius:10px;font-size:13px;outline:none;background:#fff;font-family:‘Plus Jakarta Sans’,sans-serif}
.search-input:focus{border-color:var(–mag)}
.search-results{position:absolute;top:100%;left:0;right:0;background:#fff;border-radius:10px;box-shadow:0 12px 40px rgba(26,15,46,0.15);margin-top:4px;overflow:hidden;z-index:100}
.search-item{display:block;width:100%;padding:10px 16px;border:none;border-bottom:1px solid var(–border);background:transparent;cursor:pointer;font-size:13px;text-align:left;color:var(–ink);font-family:‘Plus Jakarta Sans’,sans-serif}
.search-item:hover{background:rgba(227,59,197,0.04)}
.breadcrumb{font-size:12px;color:var(–t2);display:flex;align-items:center;gap:6px;flex-shrink:0;white-space:nowrap}

/* Content */
.main{flex:1;min-width:0}
.content{padding:28px 24px 64px;max-width:800px}
.page-title{font-family:‘Outfit’,sans-serif;font-weight:900;font-size:24px;color:var(–ink);margin-bottom:24px}

/* Components */
.card{background:var(–card);border-radius:var(–radius);box-shadow:var(–shadow);padding:24px}
.h3{font-family:‘Outfit’,sans-serif;font-weight:800;font-size:16px;color:var(–ink);margin-bottom:12px}
.mt{margin-top:28px}
.p{font-size:14px;line-height:1.7;color:rgba(26,15,46,0.7);margin-bottom:16px}
.kv{border-left:3px solid var(–mag);padding-left:16px;margin-bottom:16px}
.kv-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(–mag);margin-bottom:4px}
.kv-value{font-size:14px;line-height:1.6;color:var(–ink)}
.list-item{display:flex;gap:10px;align-items:flex-start;margin-bottom:8px}
.list-dot{color:var(–mag);flex-shrink:0;margin-top:2px;font-size:10px}
.list-text{font-size:13.5px;line-height:1.6;color:rgba(26,15,46,0.75)}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
.stat-card{background:rgba(26,15,46,0.03);border-radius:12px;padding:16px;border-left:3px solid var(–mag)}
.stat-label{font-size:11px;color:var(–t2);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:4px}
.stat-value{font-size:20px;font-weight:800;font-family:‘Outfit’,sans-serif;color:var(–ink)}
.track-card{background:rgba(26,15,46,0.03);border-radius:14px;padding:20px;margin-bottom:12px}
.track-title{font-size:18px;font-weight:800;font-family:‘Outfit’,sans-serif;color:var(–ink);margin-bottom:2px}
.track-sub{font-size:13px;font-weight:600;margin-bottom:10px}
.track-details{font-size:13px;line-height:1.6;color:rgba(26,15,46,0.6);white-space:pre-line}
.color-row{display:flex;align-items:center;gap:14px;margin-bottom:10px}
.color-swatch{width:48px;height:48px;border-radius:10px;flex-shrink:0}
.color-name{font-weight:700;font-size:13px;color:var(–ink)}
.color-hex{font-weight:400;color:var(–t2);font-family:monospace;font-size:12px}
.color-usage{font-size:12px;color:var(–t2)}
.tbl-wrap{overflow-x:auto;margin-bottom:20px;border-radius:12px;border:1px solid var(–border)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:rgba(26,15,46,0.04);padding:10px 14px;text-align:left;font-weight:700;color:var(–ink);border-bottom:1px solid var(–border);white-space:nowrap}
td{padding:10px 14px;border-bottom:1px solid var(–border);color:rgba(26,15,46,0.7);line-height:1.5}
.copy-card{margin-bottom:12px;padding:16px;background:rgba(26,15,46,0.02);border:1px solid var(–border);border-radius:var(–radius)}
.copy-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.copy-label{font-size:13px;font-weight:700;color:var(–mag)}
.copy-btn{background:rgba(26,15,46,0.06);border:none;border-radius:8px;padding:6px 14px;font-size:12px;font-weight:700;color:var(–ink);cursor:pointer;font-family:‘Plus Jakarta Sans’,sans-serif;transition:all 0.2s}
.copy-btn.done{background:var(–lime)}
.copy-text{font-size:13px;line-height:1.7;color:rgba(26,15,46,0.65);white-space:pre-wrap}
.alert{border-radius:10px;padding:14px 18px;margin-bottom:16px;font-size:13.5px;line-height:1.6}
.alert-warn{background:rgba(255,170,0,0.08);border-left:3px solid #FFA500;color:#8B6914}
.alert-err{background:rgba(227,59,60,0.06);border-left:3px solid #E33B3C;color:#A02020}
.placeholder{text-align:center;padding:48px 24px;color:var(–t2)}
.placeholder-icon{font-size:48px;margin-bottom:12px;opacity:0.3}

/* Checklist */
.check-progress{font-size:12px;color:var(–t2);margin-bottom:8px}
.check-bar{background:rgba(26,15,46,0.04);border-radius:8px;height:6px;margin-bottom:16px;overflow:hidden}
.check-fill{height:100%;background:linear-gradient(90deg,var(–mag),var(–lime));border-radius:8px;transition:width 0.3s}
.check-item{display:flex;gap:12px;align-items:flex-start;padding:10px 0;border-bottom:1px solid var(–border);cursor:pointer}
.check-item input{accent-color:var(–mag);width:18px;height:18px;margin-top:2px;flex-shrink:0;cursor:pointer}
.check-item span{font-size:14px;line-height:1.5;transition:all 0.2s}
.check-item.done span{color:var(–t2);text-decoration:line-through}

/* Dashboard */
.dash-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:28px}
.dash-stat{text-align:center;padding:16px}
.dash-stat-val{font-size:24px;font-weight:900;font-family:‘Outfit’,sans-serif}
.dash-stat-label{font-size:11px;color:var(–t2);text-transform:uppercase;letter-spacing:0.05em;margin-top:4px}
.dash-links{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px}
.dash-link{background:var(–card);border:1px solid var(–border);border-radius:12px;padding:14px 16px;text-align:left;cursor:pointer;font-size:13px;font-weight:600;color:var(–ink);font-family:‘Plus Jakarta Sans’,sans-serif;transition:all 0.2s}
.dash-link:hover{border-color:var(–mag);transform:translateY(-2px)}

.hamburger{border:none;background:none;cursor:pointer;font-size:20px;padding:4px;line-height:1}
</style>

</head>
<body>

<!-- AUTH SCREEN -->

<div id="auth-screen">
