# WAHA Plus
WAHA_API_KEY=change_me_strong_random_key
WAHA_SESSION=default

# Groq AI
GROQ_API_KEY=

# Neon PostgreSQL (same DB as TG bot)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Bitrix24 (paste webhook URL from: Apps → Developers → Incoming Webhook)
BITRIX24_WEBHOOK_URL=https://yourname.bitrix24.ru/rest/1/xxxxx/

# Telegram (for admin notifications)
BOT_TOKEN=
ADMIN_CHAT_ID=

# HuntMe CRM (interview booking)
HUNTME_CRM_LOGIN=
HUNTME_CRM_PASSWORD=

# Security
WEBHOOK_SECRET=change_me_random_secret
